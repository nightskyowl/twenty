# ============================================================
# HQ-CRM Fork: Always keep our version on upstream merge
# Uses the "ours" merge driver (configured by merge-upstream.sh)
# ============================================================
CLAUDE.md merge=ours
AGENTS.md merge=ours
.agent/** merge=ours
.gitattributes merge=ours
.mcp.json merge=ours

# Files we deleted — auto-resolve as "keep deleted" on merge
.cursor/** merge=ours
.vscode/** merge=ours

# ============================================================

* text=auto eol=lf

*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Patch files may have mixed line endings by design
*.patch -text

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

